{
  "name": "CustomPlatform",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do provedor (ex: Mistral, Together AI)"
    },
    "category": {
      "type": "string",
      "enum": [
        "Texto",
        "Imagem",
        "\u00c1udio",
        "Multimodal",
        "Outro"
      ],
      "default": "Texto",
      "description": "Tipo de modelo oferecido pela plataforma"
    },
    "plans": {
      "type": "array",
      "description": "Lista de planos/modelos dispon\u00edveis nesta plataforma",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "model_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "credits": {
            "type": "string"
          }
        }
      }
    },
    "color": {
      "type": "string",
      "description": "Cor Tailwind do texto (ex: text-pink-400)"
    },
    "bg": {
      "type": "string",
      "description": "Background Tailwind (ex: bg-pink-500/10)"
    },
    "border": {
      "type": "string",
      "description": "Border Tailwind (ex: border-pink-500/30)"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Se a plataforma est\u00e1 habilitada no seletor"
    },
    "_user_llm_config_id": {
      "type": "string",
      "description": "ID do UserLLMConfig vinculado (para sincroniza\u00e7\u00e3o autom\u00e1tica)"
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "isAuthenticated": true
      }
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}