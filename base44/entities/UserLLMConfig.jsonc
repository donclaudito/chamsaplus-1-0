{
  "name": "UserLLMConfig",
  "type": "object",
  "properties": {
    "provider": {
      "type": "string",
      "enum": [
        "openai",
        "anthropic",
        "groq",
        "google",
        "mistral",
        "together"
      ],
      "description": "Provedor do LLM"
    },
    "model_id": {
      "type": "string",
      "description": "ID do modelo (ex: gpt-4o-mini, claude-3-haiku)"
    },
    "model_label": {
      "type": "string",
      "description": "Nome amig\u00e1vel do modelo"
    },
    "api_key_encrypted": {
      "type": "string",
      "description": "Chave de API armazenada (cifrada via backend)"
    },
    "is_active": {
      "type": "boolean",
      "default": false,
      "description": "Se esta configura\u00e7\u00e3o est\u00e1 sendo usada no chat"
    },
    "base_url": {
      "type": "string",
      "description": "URL base customizada (para OpenAI-compatible APIs)"
    },
    "max_tokens": {
      "type": "number",
      "default": 2048,
      "description": "M\u00e1ximo de tokens por resposta"
    },
    "temperature": {
      "type": "number",
      "default": 0.3,
      "description": "Temperatura de gera\u00e7\u00e3o (0-1)"
    }
  },
  "required": [
    "provider",
    "model_id",
    "api_key_encrypted"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}",
      "user_condition": {
        "isAuthenticated": true
      }
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}